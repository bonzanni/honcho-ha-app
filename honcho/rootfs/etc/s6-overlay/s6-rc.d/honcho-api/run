#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Start Honcho API server (FastAPI on port 8000)
# ==============================================================================

declare CONFIG_DIR="/data/honcho"

# Load environment
if [ -f "${CONFIG_DIR}/env" ]; then
    set -a
    # shellcheck source=/dev/null
    source "${CONFIG_DIR}/env"
    set +a
fi

cd /app

bashio::log.info "Starting Honcho API server..."
# Honcho ships a native /health endpoint (v3.0.6+), used by the HA watchdog.
exec /app/.venv/bin/python -m uvicorn src.main:app \
    --host 0.0.0.0 \
    --port 8000 \
    --app-dir /app
